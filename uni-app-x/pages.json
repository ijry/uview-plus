{
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/example/components",
			"style": {
				"navigationBarTitleText": "uview-plus"
			}
		}
	],
	"subPackages": [{
		"root": "pages/componentsA",
		"pages": [
		]
	}, {
		"root": "pages/componentsB",
		"pages": [{
			"path": "card/card",
			"style": {
				"navigationBarTitleText": "卡片"
			}
		}
		]
	}, {
		"root": "pages/componentsC",
		"pages": [
		{
			"path": "calendar/calendar",
			"style": {
				"navigationBarTitleText": "日历",
				"navigationStyle": "custom"
			}
		}
		]
	},
	{
		"root": "pages/componentsD",
		"pages": [
		]
	},
	{
		"root": "pages/template",
		"pages": [
		]
	}],
	"preloadRule": {
		"pages/example/components": {
			"network": "all",
			"packages": ["pages/componentsA", "pages/componentsB"]
		}
	},
	"easycom": {
		// 注意一定要放在custom里，否则无效，https://ask.dcloud.net.cn/question/131175
		"custom": {
			"^up-(.*)": "@/uni_modules/uview-plus/components/up-$1/up-$1.uvue"
		}
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app x",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {}
}
